 "css": "/* header */\n.head-address{\n    font-size: 10px;\n    width: 270px;\n}\n\nhr {\n    border-top: 1px solid white !important\n}\n\n#header-html .print-heading{\n    border-bottom: 1px solid white;\n}\n\n/* table */\n.print-format th{\n    background-color: #ffffff !important;\n    color: black;\n}\nth.table-sr{\n text-indent: -9999px;\n  line-height: 0; /* Collapse the original line */\n}\nth.table-sr:after{\n   content: \"No\";\n  text-indent: 0;\n  display: block;\n  line-height: initial; /* New content takes up original line height */\n}\n\ntable {\n    border:none;\n}\ntable tr td, table tr th {\n    border: 1.7px solid #6e6e6e !important;\n}\n\n.total-row {\n    border: none !important;\n}\n.total-row th {\n    text-align: right !important;\n    border: none !important;\n}\n\n.total-row td {\n    font-weight: bold;\n    border: 1.7px solid #6e6e6e;\n}\ntd .value small{\n    font-size: .8em;\n}\n\n/* footer */\n.footer-notes {\n    padding-bottom: 3em;\n    padding-top: 0.7em;\n}\n\n.footerinfo {\n    background: #6D6D6D;\n    color: white;\n    font-size: 10px;\n}\n\n\n@media print {\n #footer-html {\n    display: block;\n    position: fixed;\n    bottom: 0;\n    left: 0;\n    width: 100%;\n }\n}",
 "custom_format": 1,
 "default_print_language": "es",
 "disabled": 0,
 "doc_type": "Payment Entry",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<div class=\"col-xs-12 column-break\">\n    {% set comp = frappe.db.get_value(\"Payment Entry\", {\"name\": doc.name}, as_dict=True)%}\n    {% set contact = \"\" %}\n    {% if doc.references and doc.references[0] %}\n        \n        {% set filters = {\n            \"parenttype\": \"Contact\",\n            \"link_doctype\": doc.party_type,\n            \"link_name\": doc.party_name\n        } %}\n        {% set row = frappe.db.exists(\"Dynamic Link\", filters) %}\n        \n        {% if row %}\n            {% set contact_name = frappe.db.get_value(\"Dynamic Link\", row, \"parent\") %}\n            \n            {% set contact = frappe.db.get_value(\"Contact\", contact_name, [\"first_name\", \"last_name\"], as_dict=True) %}\n            \n        {% endif %}\n    {% endif %}\n    <div class=\"col-xs-12\">             \n        <div class=\"col-xs-8\">\n            <img width=\"120px\" height=\"auto\" src=\"/files/TORRE-JP-XI-LOGO.png\" style=\" float: left; margin-top: 0px !important; margin-bottom:30px !important;\">\n        </div>\n        <div class=\"col-xs-4\" style=\"text-align:right\">\n            <h3>\n                Entrada de Pago\n            </h3>\n            <b>{{doc.name}}</b><br>\n        </div>\n    </div>\n</div>\n{% if doc.status == \"Draft\" %}\n<div class=\"text-center\" document-status=\"draft\">\n    <h4 style=\"margin: 0px;\">{{_(\"Draft\")}}</h4>\n</div>\n{% endif %}\n<br>\n<div class=\"row section-break\">\n    <div class=\"col-xs-12 column-break\">\n        <div class=\"col-xs-6 column-break\">\n          <div class=\"div-striped\" style=\"font-size: 11px;\">\n            <br>\n            <br>\n            <div><b>Nombre: </b>{{doc.party_name}}<br></div>\n            <div><b>Cantidad Pagada: </b>{{frappe.format_value(doc.paid_amount, {\"fieldtype\" : \"Currency\"})}}</div>\n            <div><b>Contacto: </b>\n                {% if contact %}\n                    {{contact.first_name or \" \"}} {{contact.last_name or \" \"}}\n                {% else %}\n                    - \n                {% endif %}\n            </div>\n            <div><b>Estado: </b>{{_(doc.status)}}</div>\n            \n          </div>\n        </div>\n        <br>\n        <br>\n        <div class=\"col-xs-6 column-break\">\n          <div class=\"div-striped\" style=\"font-size: 11px;\">\n            <div style=\"font-size: 11px\"><b>Fecha: </b>{{frappe.format_date(doc.posting_date)}}</div>\n            <!--<div style=\"font-size: 11px\"><b>Fecha de Expiracion: </b>{{ (doc.references and doc.references[0].remarks) or \"N/A\" }}</div>-->\n            <div style=\"font-size: 11px\"><b>Metodo de Pago: </b>{{doc.mode_of_payment}}</div>\n            <div><b>Referencia: </b>{{doc.reference_no or \"-\"}}</div>\n          </div>\n        </div>\n    </div>\n</div>\n\n<br>\n<br>\n<br>\n\n<div class=\"row section-break\">\n    <div class=\"col-xs-12 column-break\">\n        <div data-fieldname=\"items\" data-fieldtype=\"Table\">\n            <table class=\"table table-condensed\">\n                <thead>\n                    <tr>\n                        <th style=\"width: 300px;\" class=\"text-center\" data-fieldname=\"items\" data-fieldtype=\"Table\">\n                            <b>{{_(\"Description\")}} </b></th>\n                        <th style=\"width: 80px;\" class=\"text-center\" data-fieldname=\"items\" data-fieldtype=\"Table\">\n                            <b>{{_(\"Total\")}} </b></th>\n                        <th style=\"width: 80px;\" class=\"text-center\" data-fieldname=\"items\" data-fieldtype=\"Table\">\n                            <b>{{_(\"Pagado\")}} </b></th>\n                        <th style=\"width: 80px;\" class=\"text-center\" data-fieldname=\"items\" data-fieldtype=\"Table\">\n                            <b>{{_(\"Pendiente\")}}</b></th>\n                    </tr>\n                </thead>\n                <tbody>\n                    {% for item in doc.references %}\n                    <tr>\n                        <td class=\"text-left\" data-fieldname=\"items\" data-fieldtype=\"Table\">\n                            <div class=\"value\">\n                                {{_(item.reference_doctype)}}  - {{item.reference_name}}<br>\n                                {% if item.reference_doctype and item.reference_name %}\n                                    {% set remarks = frappe.db.get_value(item.reference_doctype, item.reference_name, \"remarks\")  %}\n                                    {% if remarks %}\n                                        <small> <b> {{remarks}} </b> </small>\n                                    {% endif %}\n                                {% endif %}\n                            </div>\n                        </td>\n\n                        <td class=\"text-right\" data-fieldname=\"items\" data-fieldtype=\"Table\">\n                            <div class=\"value\">\n                                {{frappe.format_value(item.total_amount, {\"fieldtype\":\"Currency\"})}}\n                            </div>\n                        </td>\n\n                        <td class=\"text-right\" data-fieldname=\"items\" data-fieldtype=\"Table\">\n                            <div class=\"value\">\n                                {{frappe.format_value(item.allocated_amount, {\"fieldtype\":\"Currency\"})}}\n                            </div>\n                        </td>\n\n                        <td class=\"text-right\" data-fieldname=\"items\" data-fieldtype=\"Table\">\n                            <div class=\"value\">\n                                {% set outstanding_amount = frappe.db.get_value(item.reference_doctype, item.reference_name, \"outstanding_amount\") %}\n                                {{ frappe.format_value (outstanding_amount, {\"fieldtype\": \"Currrency\"})}}\n                                <!--{{frappe.format_value(item.outstanding_amount, {\"fieldtype\":\"Currency\"})}}-->\n                            </div>\n                        </td>\n                    </tr>\n                    {% endfor %}\n                </tbody>\n               <!-- <tfoot class=\"total-row text-right\">\n                    <tr>\n\n                        <th></th>\n\n                        <th>\n                            Actual Pendiente\n                        </th>\n                        <td colspan=3 style=\"font-size:13px;\">{{frappe.db.get_value(\"Sales Invoice\", doc.outstanding_amount,\"outstanding_amount\")}}</td>\n                    </tr>-->\n            </table>\n        </div>\n    </div>\n    <div class=\"row section-break\">\n        <div class=\"col-xs-12 column-break\">\n            <div class=\"col-xs-6 colimn-break\">\n                <br>\n                <br>\n                <br>\n                <div class=\"div-striped\" style=\"font-size: 11px;\">\n                <img src=\"/files/Sello-torre-jp-xi.png\" style=\"width: 160px;\">\n                </div>\n            </div>\n            <div class=\"col-xs-6 column-break\">\n                <br>\n                <br>\n                <br>\n                <div class=\"div-striped\" style=\"font-size: 11px;\">\n                <!--<div><b>Observaciones: </b>{{doc.remarks}}</div>-->\n            </div>\n        </div>\n    </div>\n    <div id=\"footer-html\" style=\"width:100%; margin-left: 0px;\">\n        <div class=\"row section-break\">\n        <div class=\"col-xs-12\">\n\n            <br>\n            <br>\n\n            <table style=\"display: block\">\n                <tr>\n                    <td colspan=\"2\" style=\"border:none !important;\">\n                        <img src=\"/files/Lewin-Signature.png\" style=\"width: 150px;\">\n                    </td>\n                </tr>\n                <tr>\n                    <td style=\"border: none !important;\">\n                        <span style=\"font-size:12px\">Facturado por: </span>\n                    </td>\n                    <td style=\"border: none !important;\">\n                        <span>&nbsp;&nbsp;&nbsp;&nbsp;\n                            {%if doc.owner != \"Administrator\" %}\n                                {{frappe.db.get_value(\"User\", doc.owner, \"full_name\")}} &nbsp;&nbsp;&nbsp;&nbsp;\n                            \n                            {% else %}\n                                Lewin Villar &nbsp;&nbsp;&nbsp;&nbsp;\n                            {% endif %}\n                        </span>\n                    </td>\n                     <td style=\"border: none !important; width:100px;\"></td>\n                    <td style=\"border: none !important;\">\n                        <span style=\"font-size:12px\">Recibido por: </span>\n                    </td>\n                    <td style=\"border: none !important;\">\n                        _______________________\n                    </td>\n                <tr>\n            </table>\n        </div>\n    </div>\n    <br><br>\n    <br><br>\n        <div class=\"row section-break\">\n            <div class=\"col-xs-12 column-break\">\n                \n                <div class=\"text-center\" style=\"font-size: 9px;\">\n                    {%set address = frappe.db.get_value(\"Address\",{\"is_your_company_address\":1}, [\"address_line1\",\"address_line2\", \"city\", \"phone\", \"fax\", \"email_id\"], as_dict=True)%}\n                    <!--<div><b>Alternativa Advertising:</b><br></div>-->\n                    <div><b>{{address.address_line1 or \"\"}}, {{address.city or \"\"}} D.N</b></div>\n                    {% if address.address_line2 %} <div>{{address.address_line2}}</div>{%endif%}\n                \n                    <div><b>Tel\u00e9fono: {{address.phone or \" \"}} {% if address.fax %}/ {{address.fax}}{%endif%}</b></div>\n                    {% if address.email_id or \"\" %}\n                        <div><b>Email: {{address.email_id or \"\"}}</b></div>\n                    {%endif%}\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n</div>",
